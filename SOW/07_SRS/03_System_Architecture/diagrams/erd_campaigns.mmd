%% ERD Campaigns: Campaign Management and Fulfillment
%% NewPOPSys v1.38 - Campaigns & Kits + Fulfillment Domain Model
%% Mermaid ER Diagram

erDiagram
    %% =====================================================================
    %% MODULE 4: CAMPAIGNS & KITS
    %% =====================================================================

    campaigns {
        uuid id PK
        uuid brand_id FK
        uuid kit_definition_id FK
        uuid survey_version_id FK "Nullable"
        uuid published_by_user_id FK "Nullable"
        string name
        string status "DRAFT|SCHEDULED|PUBLISHED|COMPLETED|CANCELLED|ARCHIVED"
        date install_start
        date install_end
        date removal_date "Nullable"
        jsonb selection_recipe_json "Store selection criteria"
        timestamp published_at
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    kit_definitions {
        uuid id PK
        uuid brand_id FK
        string name
        string description
        boolean is_template
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    kit_items {
        uuid id PK
        uuid kit_definition_id FK
        uuid photo_rule_id FK "Nullable"
        string sku
        string name
        string description
        integer quantity
        string item_type "SIGNAGE|DISPLAY|FIXTURE|OTHER"
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    store_assignments {
        uuid id PK
        uuid campaign_id FK
        uuid store_id FK
        uuid layout_version_id FK "Pinned store layout"
        uuid survey_version_id FK "Nullable"
        string status "ASSIGNED|READY|IN_PROGRESS|SUBMITTED|REWORK_REQUIRED|COMPLETE|REOPENED|WAIVED"
        timestamp materials_received_at
        timestamp installation_started_at
        timestamp installation_completed_at
        timestamp submitted_at
        timestamp approved_at
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    assignment_items {
        uuid id PK
        uuid store_assignment_id FK
        uuid kit_item_id FK
        uuid location_slot_id FK "Nullable - optional slot mapping"
        integer quantity_assigned
        integer quantity_received
        integer quantity_installed
        string installation_notes
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    %% =====================================================================
    %% MODULE 3: SURVEYS & LAYOUTS (Linked Entities)
    %% =====================================================================

    survey_templates {
        uuid id PK
        uuid brand_id FK
        string name
        string description
        jsonb definition_json "Survey structure"
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    survey_versions {
        uuid id PK
        uuid survey_template_id FK
        integer version_number
        jsonb definition_snapshot_json
        timestamp published_at
        timestamp created_at
        timestamp deleted_at
    }

    photo_rules {
        uuid id PK
        uuid brand_id FK
        string name
        integer min_photos
        string[] required_angles "Array of angle requirements"
        string instructions
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    store_survey_responses {
        uuid id PK
        uuid store_assignment_id FK
        uuid survey_version_id FK
        jsonb responses_json
        timestamp submitted_at
        timestamp created_at
        timestamp updated_at
    }

    %% =====================================================================
    %% MODULE 5: FULFILLMENT
    %% =====================================================================

    store_orders {
        uuid id PK
        uuid campaign_id FK
        uuid store_id FK
        uuid store_assignment_id FK
        string order_type "INITIAL|REORDER|REPLACEMENT"
        string status "GENERATED|ACKNOWLEDGED|IN_PRODUCTION|KITTING|READY_TO_SHIP|PARTIALLY_SHIPPED|SHIPPED|DELIVERED|CLOSED|CANCELLED"
        string psp_order_ref "PSP internal order reference"
        string external_order_id "External system order ID"
        timestamp order_date
        timestamp expected_ship_date
        timestamp actual_ship_date
        timestamp delivered_at
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    order_lines {
        uuid id PK
        uuid store_order_id FK
        uuid kit_item_id FK
        string sku
        integer quantity_ordered
        integer quantity_shipped
        integer quantity_received
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    shipments {
        uuid id PK
        uuid store_order_id FK
        string carrier "UPS|FEDEX|USPS|OTHER"
        string[] tracking_numbers "Array of tracking IDs"
        string status "PENDING|IN_TRANSIT|OUT_FOR_DELIVERY|DELIVERED|EXCEPTION"
        timestamp shipped_at
        timestamp estimated_delivery
        timestamp actual_delivery
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    shipment_lines {
        uuid id PK
        uuid shipment_id FK
        uuid kit_item_id FK
        integer quantity_shipped
        timestamp created_at
        timestamp deleted_at
    }

    %% =====================================================================
    %% LINKED ENTITIES FROM OTHER MODULES (Reference Only)
    %% =====================================================================

    brands {
        uuid id PK
        uuid tenant_id FK
        string code UK
        string name
    }

    stores {
        uuid id PK
        uuid brand_id FK
        uuid region_id FK
        string external_store_guid UK
        string name
        string status
    }

    store_layouts {
        uuid id PK
        uuid store_id FK
        string version_label
        boolean is_current
    }

    location_slots {
        uuid id PK
        uuid store_layout_id FK
        string slot_code UK
        string name
        string location_type
    }

    users {
        uuid id PK
        string email UK
        string first_name
        string last_name
    }

    %% =====================================================================
    %% RELATIONSHIPS
    %% =====================================================================

    %% Campaign Core
    brands ||--o{ campaigns : "runs"
    brands ||--o{ kit_definitions : "owns"
    brands ||--o{ survey_templates : "creates"
    brands ||--o{ photo_rules : "defines"

    %% Kit Structure
    kit_definitions ||--o{ kit_items : "contains"
    kit_definitions ||--o{ campaigns : "used by"
    photo_rules ||--o{ kit_items : "applies to"

    %% Survey Versioning
    survey_templates ||--o{ survey_versions : "has versions"
    survey_versions ||--o{ campaigns : "used by"
    survey_versions ||--o{ store_assignments : "applies to"
    survey_versions ||--o{ store_survey_responses : "answered by"

    %% Store Assignment
    campaigns ||--o{ store_assignments : "targets"
    stores ||--o{ store_assignments : "participates in"
    store_layouts ||--o{ store_assignments : "pinned to"
    users ||--o{ campaigns : "published by"

    %% Assignment Items
    store_assignments ||--o{ assignment_items : "contains"
    kit_items ||--o{ assignment_items : "specifies"
    location_slots ||--o{ assignment_items : "placed at"

    %% Survey Responses
    store_assignments ||--o{ store_survey_responses : "submits"

    %% Order Flow
    campaigns ||--o{ store_orders : "generates"
    stores ||--o{ store_orders : "receives"
    store_assignments ||--o{ store_orders : "fulfills"

    %% Order Lines
    store_orders ||--o{ order_lines : "contains"
    kit_items ||--o{ order_lines : "ordered as"

    %% Shipment Flow
    store_orders ||--o{ shipments : "shipped via"
    shipments ||--o{ shipment_lines : "contains"
    kit_items ||--o{ shipment_lines : "shipped as"


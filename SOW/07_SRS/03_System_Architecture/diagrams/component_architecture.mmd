%% Component Architecture: NewPOPSys v1.38
%% Application Layer Components and Infrastructure
%% Mermaid Component/Flowchart Diagram

flowchart TB
    %% =====================================================================
    %% CLIENT LAYER
    %% =====================================================================

    subgraph Clients["Client Applications"]
        direction TB

        subgraph WebApps["Web Applications"]
            BrandPortal["Brand Admin Portal\n(Next.js)"]
            PSPPortal["PSP Operations Portal\n(Next.js)"]
            StorePortal["Store Portal\n(Next.js)"]
            PlatformAdmin["Platform Admin\n(Next.js)"]
        end

        subgraph MobileApps["Mobile / PWA"]
            StorePWA["Store Execution PWA\n(Next.js + PWA)"]
        end

        subgraph External["External Integrations"]
            PSP_MIS["PSP MIS/ERP"]
            BrandERP["Brand ERP"]
            CarrierAPIs["Carrier APIs\n(UPS/FedEx/USPS)"]
        end
    end

    %% =====================================================================
    %% CDN / EDGE LAYER
    %% =====================================================================

    subgraph Edge["Edge / CDN Layer"]
        CloudFront["AWS CloudFront\n(CDN)"]
        WAF["AWS WAF\n(Firewall)"]
    end

    %% =====================================================================
    %% API GATEWAY LAYER
    %% =====================================================================

    subgraph Gateway["API Gateway Layer"]
        APIGateway["API Gateway / Load Balancer"]
        RateLimiter["Rate Limiter\n(Redis-based)"]
        AuthMiddleware["Auth Middleware\n(Session/API Key)"]
    end

    %% =====================================================================
    %% APPLICATION LAYER
    %% =====================================================================

    subgraph AppLayer["Application Layer (ECS Fargate / App Runner)"]
        direction TB

        subgraph NextAPI["Next.js API Routes / Fastify"]
            AuthService["Auth Service\n- Login/Logout\n- Session Management\n- API Key Validation"]

            CampaignService["Campaign Service\n- Campaign CRUD\n- Kit Management\n- Store Selection"]

            StoreService["Store Service\n- Store Hierarchy\n- Layouts & Slots\n- Assignments"]

            FulfillmentService["Fulfillment Service\n- Orders\n- Shipments\n- Tracking"]

            ExecutionService["Execution Service\n- Photo Upload\n- Verification\n- Attestation"]

            IssueService["Issue Service\n- Issue Requests\n- Reorders\n- Resolution"]

            NotificationService["Notification Service\n- Email Dispatch\n- In-App Alerts\n- Preferences"]

            ExportService["Export Service\n- Report Generation\n- Data Exports\n- Photo Archives"]

            WebhookService["Webhook Service\n- Endpoint Mgmt\n- Delivery Queue\n- Retry Logic"]

            AuditService["Audit Service\n- Event Logging\n- Actor Tracking\n- Compliance"]
        end

        subgraph SharedModules["Shared Modules"]
            TenantContext["Tenant Context\n(Multi-tenancy)"]
            RBACEngine["RBAC Engine\n(Permission Check)"]
            ValidationLayer["Validation Layer\n(Zod/Drizzle)"]
            ErrorHandler["Error Handler\n(Sentry Integration)"]
        end
    end

    %% =====================================================================
    %% ASYNC WORKER LAYER
    %% =====================================================================

    subgraph Workers["Background Workers (BullMQ)"]
        direction LR

        WebhookWorker["Webhook Dispatcher\n- Outbox Polling\n- HMAC Signing\n- Retry w/ Backoff"]

        ExportWorker["Export Worker\n- CSV/XLSX Gen\n- PDF Reports\n- S3 Upload"]

        NotifyWorker["Notification Worker\n- Email via SES\n- Push Notifications"]

        PurgeWorker["Purge Worker\n- Soft Delete Cleanup\n- File Expiration"]

        TrackingWorker["Tracking Worker\n- Carrier API Polling\n- Status Updates"]
    end

    %% =====================================================================
    %% DATA LAYER
    %% =====================================================================

    subgraph DataLayer["Data Layer"]
        direction TB

        subgraph Primary["Primary Database"]
            PostgreSQL["PostgreSQL 15+\n(AWS RDS)\n- 41 Tables\n- 18 Enums\n- Row-Level Security"]
        end

        subgraph Cache["Cache & Queue"]
            Redis["Redis\n(ElastiCache)\n- Session Store\n- Rate Limit\n- BullMQ Queues"]
        end

        subgraph Storage["Object Storage"]
            S3["AWS S3\n- Photo Uploads\n- Export Files\n- Report Archives"]
        end
    end

    %% =====================================================================
    %% OBSERVABILITY LAYER
    %% =====================================================================

    subgraph Observability["Observability"]
        direction LR
        Sentry["Sentry\n(Error Tracking)"]
        OpenTelemetry["OpenTelemetry\n(Traces/Metrics)"]
        CloudWatch["CloudWatch\n(Logs)"]
    end

    %% =====================================================================
    %% EXTERNAL SERVICES
    %% =====================================================================

    subgraph ExternalSvc["External Services"]
        direction LR
        SES["AWS SES\n(Email)"]
        ClamAV["ClamAV\n(File Scan - Optional)"]
    end

    %% =====================================================================
    %% CONNECTIONS - Client to Edge
    %% =====================================================================

    BrandPortal --> CloudFront
    PSPPortal --> CloudFront
    StorePortal --> CloudFront
    PlatformAdmin --> CloudFront
    StorePWA --> CloudFront

    PSP_MIS --> WAF
    BrandERP --> WAF
    CarrierAPIs --> WAF

    %% =====================================================================
    %% CONNECTIONS - Edge to Gateway
    %% =====================================================================

    CloudFront --> WAF
    WAF --> APIGateway
    APIGateway --> RateLimiter
    RateLimiter --> AuthMiddleware

    %% =====================================================================
    %% CONNECTIONS - Gateway to Application
    %% =====================================================================

    AuthMiddleware --> AuthService
    AuthMiddleware --> CampaignService
    AuthMiddleware --> StoreService
    AuthMiddleware --> FulfillmentService
    AuthMiddleware --> ExecutionService
    AuthMiddleware --> IssueService
    AuthMiddleware --> NotificationService
    AuthMiddleware --> ExportService
    AuthMiddleware --> WebhookService
    AuthMiddleware --> AuditService

    %% =====================================================================
    %% CONNECTIONS - Services to Shared Modules
    %% =====================================================================

    CampaignService --> TenantContext
    StoreService --> TenantContext
    FulfillmentService --> TenantContext
    ExecutionService --> TenantContext

    CampaignService --> RBACEngine
    StoreService --> RBACEngine
    ExecutionService --> RBACEngine

    AuthService --> ValidationLayer
    CampaignService --> ValidationLayer

    AuthService --> ErrorHandler
    CampaignService --> ErrorHandler
    ExecutionService --> ErrorHandler

    %% =====================================================================
    %% CONNECTIONS - Application to Workers
    %% =====================================================================

    WebhookService --> WebhookWorker
    ExportService --> ExportWorker
    NotificationService --> NotifyWorker
    AuditService --> PurgeWorker
    FulfillmentService --> TrackingWorker

    %% =====================================================================
    %% CONNECTIONS - Application to Data
    %% =====================================================================

    AuthService --> PostgreSQL
    CampaignService --> PostgreSQL
    StoreService --> PostgreSQL
    FulfillmentService --> PostgreSQL
    ExecutionService --> PostgreSQL
    IssueService --> PostgreSQL
    AuditService --> PostgreSQL

    AuthService --> Redis
    RateLimiter --> Redis
    WebhookWorker --> Redis
    ExportWorker --> Redis
    NotifyWorker --> Redis
    PurgeWorker --> Redis
    TrackingWorker --> Redis

    ExecutionService --> S3
    ExportWorker --> S3

    %% =====================================================================
    %% CONNECTIONS - Workers to External
    %% =====================================================================

    NotifyWorker --> SES
    ExecutionService --> ClamAV
    TrackingWorker --> CarrierAPIs

    %% =====================================================================
    %% CONNECTIONS - Webhooks Outbound
    %% =====================================================================

    WebhookWorker --> PSP_MIS
    WebhookWorker --> BrandERP

    %% =====================================================================
    %% CONNECTIONS - Observability
    %% =====================================================================

    ErrorHandler --> Sentry
    AppLayer --> OpenTelemetry
    AppLayer --> CloudWatch
    Workers --> OpenTelemetry
    Workers --> CloudWatch

    %% =====================================================================
    %% STYLING
    %% =====================================================================

    classDef clientApp fill:#e1f5fe,stroke:#01579b
    classDef mobileApp fill:#f3e5f5,stroke:#4a148c
    classDef external fill:#fff3e0,stroke:#e65100
    classDef edge fill:#e8f5e9,stroke:#1b5e20
    classDef gateway fill:#fce4ec,stroke:#880e4f
    classDef service fill:#e3f2fd,stroke:#0d47a1
    classDef shared fill:#f5f5f5,stroke:#616161
    classDef worker fill:#fff8e1,stroke:#ff6f00
    classDef database fill:#e8eaf6,stroke:#1a237e
    classDef cache fill:#ffebee,stroke:#b71c1c
    classDef storage fill:#e0f2f1,stroke:#004d40
    classDef observe fill:#fafafa,stroke:#212121
    classDef extsvc fill:#ede7f6,stroke:#311b92

    class BrandPortal,PSPPortal,StorePortal,PlatformAdmin clientApp
    class StorePWA mobileApp
    class PSP_MIS,BrandERP,CarrierAPIs external
    class CloudFront,WAF edge
    class APIGateway,RateLimiter,AuthMiddleware gateway
    class AuthService,CampaignService,StoreService,FulfillmentService,ExecutionService,IssueService,NotificationService,ExportService,WebhookService,AuditService service
    class TenantContext,RBACEngine,ValidationLayer,ErrorHandler shared
    class WebhookWorker,ExportWorker,NotifyWorker,PurgeWorker,TrackingWorker worker
    class PostgreSQL database
    class Redis cache
    class S3 storage
    class Sentry,OpenTelemetry,CloudWatch observe
    class SES,ClamAV extsvc

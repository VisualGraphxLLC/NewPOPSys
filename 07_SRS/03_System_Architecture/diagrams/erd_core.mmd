%% ERD Core: Tenancy, Identity, and Store Hierarchy
%% NewPOPSys v1.38 - Core Domain Model
%% Mermaid ER Diagram

erDiagram
    %% =====================================================================
    %% MODULE 1: TENANCY & IDENTITY
    %% =====================================================================

    tenants {
        uuid id PK
        string slug UK "Unique PSP identifier"
        string name
        string subscription_tier "STARTER|PROFESSIONAL|ENTERPRISE"
        jsonb settings_json "Tenant-level configuration"
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    brands {
        uuid id PK
        uuid tenant_id FK
        string code UK "Unique within tenant"
        string name
        string logo_url
        jsonb settings_json "Brand-specific configuration"
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    users {
        uuid id PK
        string email UK
        string password_hash
        string first_name
        string last_name
        boolean is_active
        timestamp email_verified_at
        timestamp last_login_at
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    memberships {
        uuid id PK
        uuid user_id FK
        uuid tenant_id FK
        uuid brand_id FK "Nullable - PSP users have no brand"
        uuid region_scope_id FK "Nullable - Regional scoping"
        uuid store_scope_id FK "Nullable - Store scoping"
        string role "PLATFORM_ADMIN|PSP_ADMIN|PSP_OPS|BRAND_ADMIN|CAMPAIGN_MANAGER|REGIONAL_MANAGER|STORE_MANAGER|STORE_OPERATOR"
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    api_keys {
        uuid id PK
        uuid tenant_id FK
        string key_hash UK
        string name
        string[] scopes "Array of API scope permissions"
        timestamp expires_at
        timestamp last_used_at
        timestamp created_at
        timestamp deleted_at
    }

    %% =====================================================================
    %% MODULE 2: STORES & GROUPING
    %% =====================================================================

    regions {
        uuid id PK
        uuid brand_id FK
        uuid parent_region_id FK "Self-reference for hierarchy"
        string name
        string code
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    districts {
        uuid id PK
        uuid brand_id FK
        uuid region_id FK
        string name
        string code
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    territories {
        uuid id PK
        uuid brand_id FK
        uuid region_id FK
        uuid district_id FK "Nullable"
        string name
        string code
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    stores {
        uuid id PK
        uuid brand_id FK
        uuid region_id FK
        uuid district_id FK "Nullable"
        uuid territory_id FK "Nullable"
        string external_store_guid UK "Brand's store ID"
        string name
        string address_line1
        string address_line2
        string city
        string state
        string postal_code
        string country
        string phone
        string status "ACTIVE|INACTIVE|PENDING"
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    store_groups {
        uuid id PK
        uuid brand_id FK
        string name
        jsonb selection_criteria_json "Dynamic group definition"
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    store_group_memberships {
        uuid id PK
        uuid store_id FK
        uuid store_group_id FK
        timestamp created_at
        timestamp deleted_at
    }

    store_invitations {
        uuid id PK
        uuid brand_id FK
        string email
        string token UK
        uuid store_id FK "Nullable - assigned store"
        timestamp expires_at
        timestamp accepted_at
        timestamp created_at
    }

    %% =====================================================================
    %% MODULE 3: SURVEYS & LAYOUTS
    %% =====================================================================

    store_layouts {
        uuid id PK
        uuid store_id FK
        string version_label
        boolean is_current
        jsonb layout_definition_json
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    location_slots {
        uuid id PK
        uuid store_layout_id FK
        string slot_code UK "Unique within layout"
        string name
        string description
        string location_type "WINDOW|SHELF|ENDCAP|FLOOR|WALL"
        integer display_order
        timestamp created_at
        timestamp updated_at
        timestamp deleted_at
    }

    %% =====================================================================
    %% RELATIONSHIPS
    %% =====================================================================

    %% Tenancy
    tenants ||--o{ brands : "contains"
    tenants ||--o{ memberships : "authorizes"
    tenants ||--o{ api_keys : "owns"

    %% Brand relationships
    brands ||--o{ regions : "has"
    brands ||--o{ districts : "has"
    brands ||--o{ territories : "has"
    brands ||--o{ stores : "operates"
    brands ||--o{ store_groups : "defines"
    brands ||--o{ memberships : "scopes"
    brands ||--o{ store_invitations : "sends"

    %% User/Membership
    users ||--o{ memberships : "has"

    %% Store hierarchy
    regions ||--o{ regions : "contains (parent)"
    regions ||--o{ districts : "contains"
    regions ||--o{ territories : "contains"
    regions ||--o{ stores : "contains"
    regions ||--o{ memberships : "scopes"

    districts ||--o{ territories : "contains"
    districts ||--o{ stores : "contains"

    territories ||--o{ stores : "contains"

    %% Store relationships
    stores ||--o{ store_group_memberships : "belongs to"
    stores ||--o{ store_layouts : "has"
    stores ||--o{ memberships : "scopes"
    stores ||--o{ store_invitations : "targets"

    store_groups ||--o{ store_group_memberships : "includes"

    %% Layout relationships
    store_layouts ||--o{ location_slots : "defines"
